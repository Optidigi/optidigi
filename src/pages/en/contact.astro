---
import MainLayout from "../../layouts/MainLayout.astro";
import Section from "../../components/sections/Section.astro";
import SectionTitle from "../../components/ui/SectionTitle.astro";
import Card from "../../components/ui/Card.astro";
import ContactSection from "../../components/sections/Contact.astro";
import { locales, pages, sections } from "../../i18n";

const locale = locales.en;
const page = pages.en.contact;
const content = sections.en;
---

<MainLayout
  title={page.title}
  description={page.description}
  alternates={page.alternates}
  {...locale}
>
  <Section id="contact-details">
    <div class="py-8 lg:py-16">
      <SectionTitle
        sectionTitle="Contact details"
        description="Email your question or project idea to Optidigi."
      />
      <Card>
        <div class="grid gap-10 rounded-[45px] bg-gray p-[60px] lg:grid-cols-2">
          <div class="flex flex-col gap-4">
            <h1 class="text-4xl font-medium leading-none md:text-6xl">Get in touch</h1>
            <p>Optidigi V.O.F.</p>
            <p>Email: <a class="underline" href="mailto:info@optidigi.nl">info@optidigi.nl</a></p>
          </div>
          <div class="flex flex-col gap-4">
            <h2 class="text-3xl font-medium">Introductory call</h2>
            <p>
              Briefly describe what you want to build or improve. Then we
              determine whether a 15-minute introductory call makes sense.
            </p>
            <a href="mailto:info@optidigi.nl?subject=Introductory%20call%20Optidigi" class="btn-primary text-center">Email Optidigi</a>
          </div>
        </div>
      </Card>
    </div>
  </Section>
  <ContactSection sectionTitle={content.contactSection.title} description={content.contactSection.description} form={content.contactSection.form} />
</MainLayout>
