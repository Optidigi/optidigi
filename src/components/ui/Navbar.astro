---
import { Astronav } from "astro-navbar";

type NavItem = { href: string; label: string };
type NavButton = { href: string; label: string };

const menuitems: NavItem[] = Astro.props.menuitems || [
  { href: "/over-ons", label: "Over ons" },
  { href: "/#services", label: "Oplossingen" },
  { href: "/prijzen", label: "Prijzen" },
  { href: "/contact", label: "Contact" },
];
const navButton: NavButton = Astro.props.navButton || {
  href: "mailto:info@optidigi.nl?subject=Introductiecall%20Optidigi",
  label: "Plan introductiecall",
};
const home: string = Astro.props.home || "/";
const languageItem = menuitems.find((item) => item.label === "EN" || item.label === "NL");
const primaryMenuItems = menuitems.filter((item) => item !== languageItem);
const languageAria =
  languageItem?.label === "EN" ? "Switch to English" : "Schakel naar Nederlands";
const currentLanguage = languageItem?.label === "EN" ? "NL" : "EN";
const currentLanguageName = currentLanguage === "NL" ? "Nederlands" : "English";
const targetLanguageName = languageItem?.label === "EN" ? "English" : "Nederlands";
const currentPath = Astro.url.pathname;
const languageOptions = languageItem
  ? [
      { label: currentLanguage, name: currentLanguageName, href: currentPath, current: true },
      { label: languageItem.label, name: targetLanguageName, href: languageItem.href, current: false },
    ]
  : [];
---

<div class="mt-20">
  <nav class="w-full top-0 left-0 z-50 fixed bg-white">
    <header class="flex flex-col lg:flex-row justify-between items-center my-5 px-6 md:px-32">
      <Astronav>
        <div class="flex w-full lg:w-auto items-center justify-between">
          <a href={home} class="flex items-center space-x-3 rtl:space-x-reverse">
            <img src="/Logo.svg" class="h-8" alt="Optidigi" />
          </a>
          <div class="block lg:hidden">
            <div id="menu-icon" class="w-8 h-8 text-black cursor-pointer">
              <!-- Open (hamburger) icon -->
              <svg id="open-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="w-8 h-8">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
              <!-- Close (X) icon -->
              <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="w-8 h-8 hidden">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </div>
          </div>
        </div>
        
        <nav class="hidden w-full lg:w-auto mt-2 lg:flex lg:mt-0" id="menu-items">
          <ul class="font-medium flex flex-col p-4 lg:p-0 mt-4 border rounded-lg lg:flex-row lg:space-x-8 lg:mt-0 lg:border-0">
            {primaryMenuItems.map((item) => (
              <li>
                <a 
                  href={item.href} 
                  class="mobile-nav-link block py-2 px-3 text-black rounded lg:bg-transparent lg:p-0"
                  data-close-menu="true"
                >
                  {item.label}
                </a>
              </li>
            ))}
            <div class="lg:hidden flex items-center justify-center mt-3 gap-4">
              <a 
                class="mobile-nav-link px-9 py-5 rounded-2xl border border-zinc-900 bg-white hover:bg-black text-black hover:text-white inline-flex" 
                href={navButton.href}
                data-close-menu="true"
              >
                <h2 class="text-center text-xl font-normal leading-7">{navButton.label}</h2>
              </a>
            </div>
            {
              languageItem && (
                <div class="lg:hidden relative flex items-center justify-center mt-3" data-language-switch>
                  <button
                    type="button"
                    class="inline-flex items-center gap-2 px-3 py-2 text-black hover:underline"
                    aria-label={languageAria}
                    aria-expanded="false"
                    data-language-toggle
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="w-5 h-5" aria-hidden="true">
                      <circle cx="12" cy="12" r="10"></circle>
                      <path d="M2 12h20"></path>
                      <path d="M12 2a15.3 15.3 0 0 1 0 20"></path>
                      <path d="M12 2a15.3 15.3 0 0 0 0 20"></path>
                    </svg>
                    <span>{currentLanguage}</span>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="w-4 h-4" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m6 9 6 6 6-6"></path>
                    </svg>
                  </button>
                  <div class="hidden absolute top-full mt-2 z-50 min-w-[150px] rounded-[14px] border border-zinc-900 bg-white p-2 text-black" data-language-menu>
                    {languageOptions.map((option) => (
                      <a
                        class="mobile-nav-link flex items-center justify-between rounded-lg px-3 py-2 hover:bg-gray"
                        href={option.href}
                        aria-current={option.current ? "page" : undefined}
                        data-close-menu={!option.current ? "true" : undefined}
                      >
                        <span>{option.name}</span>
                        <span>{option.label}</span>
                      </a>
                    ))}
                  </div>
                </div>
              )
            }
          </ul>
        </nav>
      </Astronav>

      <div>
        <div class="hidden lg:flex items-center gap-4">
          {
            languageItem && (
              <div class="relative" data-language-switch>
                <button
                  type="button"
                  class="inline-flex items-center gap-2 px-2 py-2 text-black hover:underline"
                  aria-label={languageAria}
                  aria-expanded="false"
                  data-language-toggle
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="w-5 h-5" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"></circle>
                    <path d="M2 12h20"></path>
                    <path d="M12 2a15.3 15.3 0 0 1 0 20"></path>
                    <path d="M12 2a15.3 15.3 0 0 0 0 20"></path>
                  </svg>
                  <span class="font-medium">{currentLanguage}</span>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="w-4 h-4" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m6 9 6 6 6-6"></path>
                  </svg>
                </button>
                <div class="hidden absolute right-0 top-full mt-2 z-50 min-w-[150px] rounded-[14px] border border-zinc-900 bg-white p-2 text-black" data-language-menu>
                  {languageOptions.map((option) => (
                    <a
                      class="flex items-center justify-between rounded-lg px-3 py-2 hover:bg-gray"
                      href={option.href}
                      aria-current={option.current ? "page" : undefined}
                    >
                      <span>{option.name}</span>
                      <span>{option.label}</span>
                    </a>
                  ))}
                </div>
              </div>
            )
          }
          <a class="px-9 py-5 rounded-2xl border border-zinc-900 bg-white hover:bg-black text-black hover:text-white inline-flex" href={navButton.href}>
            <h2 class="text-center text-xl font-normal leading-7">{navButton.label}</h2>
          </a>
        </div>
      </div>
    </header>
  </nav>
</div>

<script is:inline>
  // Get references to the menu icon, open/close icons, and menu items
  const menuIcon = document.getElementById('menu-icon');
  const openIcon = document.getElementById('open-icon');
  const closeIcon = document.getElementById('close-icon');
  const menuItems = document.getElementById('menu-items');
  const closeMenuItems = document.querySelectorAll('[data-close-menu="true"]');  // Select all items with the 'data-close-menu' attribute
  const languageSwitches = document.querySelectorAll('[data-language-switch]');

  // Toggle the menu visibility and icon when the menu icon is clicked
  menuIcon.addEventListener('click', () => {
    menuItems.classList.toggle('hidden');  // Toggle the 'hidden' class on the menu

    // Toggle between open and close icons
    openIcon.classList.toggle('hidden');
    closeIcon.classList.toggle('hidden');
  });

  // Close the menu when any item is clicked
  closeMenuItems.forEach(item => {
    item.addEventListener('click', () => {
      menuItems.classList.add('hidden');  // Add the 'hidden' class to hide the menu
      openIcon.classList.remove('hidden');  // Show the open (hamburger) icon
      closeIcon.classList.add('hidden');  // Hide the close (X) icon
    });
  });

  languageSwitches.forEach((switcher) => {
    const toggle = switcher.querySelector('[data-language-toggle]');
    const dropdown = switcher.querySelector('[data-language-menu]');

    toggle?.addEventListener('click', (event) => {
      event.stopPropagation();
      languageSwitches.forEach((otherSwitcher) => {
        if (otherSwitcher !== switcher) {
          otherSwitcher.querySelector('[data-language-menu]')?.classList.add('hidden');
          otherSwitcher.querySelector('[data-language-toggle]')?.setAttribute('aria-expanded', 'false');
        }
      });
      dropdown?.classList.toggle('hidden');
      toggle.setAttribute('aria-expanded', dropdown?.classList.contains('hidden') ? 'false' : 'true');
    });
  });

  document.addEventListener('click', () => {
    languageSwitches.forEach((switcher) => {
      switcher.querySelector('[data-language-menu]')?.classList.add('hidden');
      switcher.querySelector('[data-language-toggle]')?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
