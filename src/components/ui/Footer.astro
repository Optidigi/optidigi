---
import { Image } from "astro:assets";
import Logo from "../../assets/logo-alt.svg";
import ShortForm from "../ui/ShortForm.astro";

type FooterLink = { name: string; href: string };
type FooterText = {
  contactTitle: string;
  emailLabel: string;
  shortFormPlaceholder: string;
  shortFormButton: string;
};

const links: FooterLink[] = Astro.props.links || [
  { name: "Over ons", href: "/over-ons" },
  { name: "Oplossingen", href: "/#services" },
  { name: "Prijzen", href: "/prijzen" },
  { name: "Contact", href: "/contact" },
];
const footer: FooterText = Astro.props.footer || {
  contactTitle: "Contact",
  emailLabel: "E-mail",
  shortFormPlaceholder: "E-mail",
  shortFormButton: "Mail Optidigi",
};
const home: string = Astro.props.home || "/";
---

<section class="sm:px-5">
  <div class="w-full max-w-[1240px] mx-auto">
    <div
      class="px-[15px] bg-dark text-gray py-[55px] lg:px-[60px] sm:rounded-t-[45px]"
    >
      <div>
        <div
          class="flex flex-col lg:flex-row gap-7 items-center justify-between"
        >
          <picture>
            <a href={home}>
              <Image src={Logo} alt="Optidigi" />
            </a>
          </picture>
          <ul class="flex flex-col sm:flex-row gap-5">
            {
              links.map((link) => {
                return (
                  <li class="text-center">
                    <a class="underline" href={link.href}>
                      {link.name}
                    </a>
                  </li>
                );
              })
            }
          </ul>
        </div>

        <div class="flex flex-col lg:flex-row mt-[66px] mb-[51px]">
          <div
            class="flex text-center lg:text-start flex-col w-full lg:w-[30%]"
          >
            <h3 class="mb-5 text-center md:text-left text-2xl text-white">{footer.contactTitle}</h3>
            <div class="flex flex-col justify-between gap-4">
              <span> {footer.emailLabel}: info@optidigi.nl </span>
            </div>
          </div>
          <div class="flex-grow my-10 lg:my-0 lg:ml-12">
            <ShortForm placeholder={footer.shortFormPlaceholder} buttonLabel={footer.shortFormButton} />
          </div>
        </div>
      </div>

      <div class="h-[1px] bg-gray mb-5"></div>
      <div
        class="flex flex-col lg:flex-row h-20 justify-center mt-4 text-center md:justify-between md:mt-0"
      >
        <span>2026 Optidigi</span>
      </div>
    </div>
  </div>
</section>
