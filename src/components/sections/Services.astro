---
import SectionTitle from "../ui/SectionTitle.astro";
import ServiceCard from "../ui/ServiceCard.astro";
import Section from "./Section.astro";

import c1 from "../../assets/pics/card-pic1.png";
import c2 from "../../assets/pics/card-pic2.png";
import c3 from "../../assets/pics/card-pic3.png";
import c4 from "../../assets/pics/card-pic4.png";
import c5 from "../../assets/pics/card-pic5.png";
import c6 from "../../assets/pics/card-pic6.png";

const defaultCards = [
  {
    index: 1,
    titleTop: "Websites",
    titleBottom: "op maat",
    img: c1,
    alt: "Illustratie voor websites op maat",
    link: "/contact/",
  },
  {
    index: 2,
    titleTop: "Webapps en",
    titleBottom: "portalen",
    img: c2,
    alt: "Illustratie voor webapplicaties en portalen",
    link: "/contact/",
  },
  {
    index: 3,
    titleTop: "Apps en",
    titleBottom: "dashboards",
    img: c3,
    alt: "Illustratie voor apps en dashboards",
    link: "/contact/",
  },
  {
    index: 1,
    titleTop: "Koppelingen en",
    titleBottom: "automatisering",
    img: c4,
    alt: "Illustratie voor koppelingen en automatisering",
    link: "/contact/",
  },
  {
    index: 2,
    titleTop: "Maatwerk",
    titleBottom: "software",
    img: c5,
    alt: "Illustratie voor maatwerksoftware",
    link: "/contact/",
  },
  {
    index: 3,
    titleTop: "Data en",
    titleBottom: "AI-oplossingen",
    img: c6,
    alt: "Illustratie voor data en AI-oplossingen",
    link: "/contact/",
  },
];

const {
  sectionTitle = "Oplossingen",
  title,
  description = "Praktische digitale oplossingen voor ondernemers en groeiende teams die minder handmatig werk en meer overzicht willen.",
  moreInfo = "Meer info",
  pathPrefix = "",
  cards: cardText,
} = Astro.props;

const cards = defaultCards.map((card, index) => {
  const text = cardText?.[index];

  return {
    ...card,
    titleTop: text?.[0] || card.titleTop,
    titleBottom: text?.[1] || card.titleBottom,
    alt: text?.[2] || card.alt,
    link: `${pathPrefix}/contact/`.replace("//", "/"),
  };
});
---

<Section id="services">
  <div class="mt-[140px] mb-5">
    <SectionTitle sectionTitle={title || sectionTitle} description={description} />
    <div class="grid lg:grid-cols-2 lg:grid-rows-3 gap-10">
      {
        cards.map((card) => (
          <ServiceCard
            index={card.index}
            titleTop={card.titleTop}
            titleBottom={card.titleBottom}
            img={card.img}
            alt={card.alt}
            link={card.link}
            moreInfo={moreInfo}
          />
        ))
      }
    </div>
  </div>
</Section>
